{
  "name": "children-time-pwa",
  "version": "0.1.0",
  "description": "儿童时间小管家 PWA",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "serve": "npx http-server frontend -p 8080 -c-1",
    "dev": "concurrently \"npm run start\" \"npm run serve\"",
    "test": "node --check backend/server.js && echo 'backend: syntax ok' && node --check frontend/app.js && echo 'frontend: syntax ok'",
    "lint": "echo 'lint 待实现'"
  },
  "keywords": ["pwa", "children", "time-management"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1"
  }
}
